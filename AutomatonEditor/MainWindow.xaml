<Window x:Class="AutomatonEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edytor Automatów"
        Width="980" Height="650"
        MinWidth="700" MinHeight="500">
    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Right" Width="220"
                Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">

                    <TextBlock Text="Edycja stanu" FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button x:Name="DeleteButton" Content="Usuń stan"
                            IsEnabled="False" Padding="6,5" Margin="0,0,0,10"
                            Click="DeleteState_Click"/>

                    <CheckBox x:Name="AcceptingCheckbox"
                              Content="Oznacz jako akceptujący"
                              IsEnabled="False" Margin="0,0,0,7"
                              Click="Accepting_Click"/>

                    <CheckBox x:Name="InitialCheckbox"
                              Content="Oznacz jako początkowy"
                              IsEnabled="False" Margin="0,0,0,18"
                              Click="Initial_Click"/>

                    <Separator Margin="0,0,0,14"/>

                    <TextBlock Text="Dodaj przejście" FontSize="15" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <TextBlock Text="Stan źródłowy" FontSize="11" Foreground="#555555"
                               Margin="0,0,0,3"/>
                    <ComboBox x:Name="SourceStateCombo"
                              ItemsSource="{Binding States}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Stan docelowy" FontSize="11" Foreground="#555555"
                               Margin="0,0,0,3"/>
                    <ComboBox x:Name="TargetStateCombo"
                              ItemsSource="{Binding States}"
                              DisplayMemberPath="Name"
                              Margin="0,0,0,12"/>

                    <Button Content="Dodaj przejście"
                            Padding="6,5" Click="AddTransition_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid x:Name="DrawingArea"
              Background="WhiteSmoke"
              ClipToBounds="True"
              PreviewMouseLeftButtonDown="DrawingArea_PreviewMouseLeftButtonDown"
              PreviewMouseMove="DrawingArea_PreviewMouseMove"
              PreviewMouseLeftButtonUp="DrawingArea_PreviewMouseLeftButtonUp">

            <ItemsControl ItemsSource="{Binding Transitions}" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line X1="{Binding X1}" Y1="{Binding Y1}"
                              X2="{Binding X2}" Y2="{Binding Y2}"
                              Stroke="#444444" StrokeThickness="2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl x:Name="StatesControl" ItemsSource="{Binding States}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="50" Height="50" Background="Transparent">
                            <Ellipse x:Name="OuterEllipse"
                                     Width="50" Height="50"
                                     Fill="White" Stroke="#222222" StrokeThickness="2"/>
                            <Ellipse x:Name="InnerEllipse"
                                     Width="37" Height="37"
                                     Fill="Transparent" Stroke="#222222" StrokeThickness="1.5"
                                     Visibility="Collapsed"/>
                            <TextBlock Text="{Binding Name}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="12" FontWeight="SemiBold"
                                       IsHitTestVisible="False"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsAccepting}" Value="True">
                                <Setter TargetName="InnerEllipse" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsInitial}" Value="True">
                                <Setter TargetName="OuterEllipse" Property="Stroke" Value="#E65100"/>
                                <Setter TargetName="OuterEllipse" Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="OuterEllipse" Property="Fill" Value="#BBDEFB"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Grid>
    </DockPanel>
</Window>
