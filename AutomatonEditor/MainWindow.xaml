<Window
    x:Class="AutomatonEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edytor Automatów"
    Width="800"
    Height="600">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <Canvas x:Name="Plotno"
                Background="WhiteSmoke"
                MouseLeftButtonDown="PMouseLeftButtonDown"
                Width="600"
                Height = "584">
            </Canvas>
            
            <StackPanel Width="194">
                <TextBlock Text="Edycja Stanów" FontSize="20" FontWeight="Bold"></TextBlock>

                <Button x:Name="usunButton" Margin="10,10" BorderBrush="Black" BorderThickness="1" Click="DestroyActive" IsEnabled="False">
                    <TextBlock Text="Usuń stan" FontSize="13"></TextBlock>
                </Button>

                <CheckBox x:Name="CheckBoxAkceptujacy"  IsEnabled="False" Click="UstawAkceptujacy">
                    <TextBlock Text="Oznacz jako akceptujący" FontSize="13"></TextBlock>
                </CheckBox>
                <CheckBox x:Name="CheckBoxPoczatkowy"  IsEnabled="False" Click="UstawPoczatkowy">
                    <TextBlock Text="Oznacz jako początkowy" FontSize="13"></TextBlock>
                </CheckBox>
            </StackPanel>
        </StackPanel>
        
    </Grid>
</Window>